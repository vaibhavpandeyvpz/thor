{
  "name": "thor",
  "version": "0.1.0",
  "description": "CLI for flashing Samsung firmware over serial download mode.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "thor": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "samsung",
    "odin",
    "flash",
    "firmware",
    "cli",
    "serial"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\"",
    "bun:test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "lz4": "^0.6.5",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@types/lz4": "^0.6.4",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
