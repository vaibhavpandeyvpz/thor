{
  "name": "thorjs",
  "version": "0.3.0",
  "description": "CLI for flashing Samsung firmware over serial download mode.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "thorjs": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "samsung",
    "odin",
    "flash",
    "firmware",
    "cli",
    "serial"
  ],
  "author": {
    "name": "Vaibhav Pandey",
    "email": "contact@vaibhavpandey.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaibhavpandeyvpz/thor.git"
  },
  "bugs": {
    "url": "https://github.com/vaibhavpandeyvpz/thor/issues"
  },
  "homepage": "https://github.com/vaibhavpandeyvpz/thor#readme",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\"",
    "bun:test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^5.2.1",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "lz4": "^0.6.5",
    "react": "^18.3.1",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@types/lz4": "^0.6.4",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.29",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
